{
  "name": "nextjs-unused-media-checker",
  "displayName": "Next.js Unused Media Checker",
  "description": "A VSCode extension to detect unused media files in your Next.js project's public directory.",
  "version": "0.1.11",
  "publisher": "Takanaz",
  "author": {
    "name": "Takanaz"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Takanaz/nextjs-unused-media-checker.git"
  },
  "bugs": {
    "url": "https://github.com/Takanaz/nextjs-unused-media-checker/issues"
  },
  "homepage": "https://github.com/Takanaz/nextjs-unused-media-checker#readme",
  "keywords": [
    "nextjs",
    "media",
    "unused",
    "optimization",
    "performance",
    "static-analysis"
  ],
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Linters"
  ],
  "activationEvents": [
    "workspaceContains:**/package.json"
  ],
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1a1a1a",
    "theme": "dark"
  },
  "main": "./dist/extension.js",
  "packageManager": "pnpm@10.32.1",
  "contributes": {
    "commands": [
      {
        "command": "nextjs-unused-media-checker.checkUnusedMedia",
        "title": "%command.checkUnusedMedia%"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "nextjs-unused-media-checker.excludePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/node_modules/**",
            "**/build/**",
            "**/dist/**",
            "**/.next/**",
            "**/out/**",
            "**/.git/**",
            "**/coverage/**",
            "**/.cache/**"
          ],
          "description": "%config.excludePatterns.description%"
        },
        "nextjs-unused-media-checker.mediaExtensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".jpg",
            ".jpeg",
            ".png",
            ".gif",
            ".svg",
            ".webp",
            ".ico",
            ".mp4",
            ".webm",
            ".mp3",
            ".avif",
            ".bmp",
            ".tiff",
            ".ogg",
            ".wav",
            ".avi",
            ".mov"
          ],
          "description": "%config.mediaExtensions.description%"
        },
        "nextjs-unused-media-checker.publicDirectory": {
          "type": "string",
          "default": "public",
          "description": "%config.publicDirectory.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "format": "biome format",
    "format:fix": "biome format --write",
    "check": "biome check",
    "check:fix": "biome check --write",
    "test": "vscode-test",
    "ovsx:package": "ovsx package",
    "ovsx:publish": "ovsx publish -p $OVSX_PAT",
    "release:ovsx": "pnpm run package && ovsx publish -p $OVSX_PAT"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@types/mocha": "^10.0.10",
    "@types/node": "~25.5.0",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.4",
    "lefthook": "^2.1.4",
    "npm-run-all": "^4.1.5",
    "ovsx": "^0.10.9",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "undici": "7.24.0",
      "underscore": "1.13.8",
      "serialize-javascript": "7.0.3",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "minimatch@>=10.0.0 <10.2.3": "10.2.3",
      "ajv@>=7.0.0-alpha.0 <8.18.0": "8.18.0",
      "qs@>=6.7.0 <=6.14.1": "6.14.2",
      "markdown-it@>=13.0.0 <14.1.1": "14.1.1"
    },
    "onlyBuiltDependencies": [
      "@vscode/vsce-sign",
      "esbuild",
      "keytar",
      "lefthook"
    ]
  }
}
